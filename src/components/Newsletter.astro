---
import { strings, type Lang } from "../i18n/strings";

interface Props {
  lang?: Lang;
}

const { lang = "tr" } = Astro.props;
const t = strings[lang].newsletter;
---

<section class="newsletter">

  <div class="newsletter-inner">

    <img class="newsletter-image" src={t.image} alt={t.imageAlt} loading="lazy" />

    <div class="newsletter-text">
      <p class="newsletter-desc">{t.description}</p>
      <p class="newsletter-line">{t.line}</p>
    </div>

    <a
      href={t.buttonHref}
      class="newsletter-button"
      target="_blank"
      rel="noopener noreferrer"
    >{t.button}</a>

  </div>

</section>

<style>
  .newsletter {
    background: #0A0A0A;
    color: var(--color-paper);
  }

  .newsletter-inner {
    width: min(100% - 4rem, 720px);

    margin-inline: auto;

    padding-block: 3.5rem;

    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;

    gap: 2rem;
  }

  .newsletter-image {
    display: block;

    width: 100%;
    max-width: 580px;
    height: auto;

    /* Cover already has a black background, so it blends — no border. */
    object-fit: contain;
  }

  .newsletter-text {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .newsletter-desc {
    max-width: 52ch;

    margin-inline: auto;

    font-size: 1.15rem;
    line-height: 1.7;

    color: var(--color-paper);
  }

  .newsletter-line {
    font-size: 0.95rem;

    color: rgba(255, 255, 255, 0.65);
  }

  .newsletter-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;

    padding: 1.1rem 2rem;

    background: var(--color-teal);
    color: var(--color-ink);

    text-decoration: none;

    font-weight: 700;

    white-space: nowrap;
  }

  .newsletter-button:hover {
    opacity: 0.9;
  }

  @media (max-width: 600px) {
    .newsletter-inner {
      padding-block: 2.5rem;
    }

    .newsletter-button {
      width: 100%;
    }
  }
</style>
