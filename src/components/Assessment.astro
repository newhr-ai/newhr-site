---
import { strings, assessmentPath, type Lang } from "../i18n/strings";

interface Props {
  lang?: Lang;
}

const { lang = "tr" } = Astro.props;
const t = strings[lang].assessment;
const assessmentHref = assessmentPath(lang);
---

<section class="assessment">

  <div class="assessment-inner">

    <div class="assessment-left">

      <p class="assessment-label">{t.label}</p>

      <h2>
        {t.headingPart1}
        <span>{t.headingAccent}</span>
      </h2>

      <p class="assessment-text">{t.body}</p>

      <div class="assessment-list">

        <div class="assessment-item">
          <span class="square"></span>
          <p>{t.list1}</p>
        </div>

        <div class="assessment-item">
          <span class="square"></span>
          <p>{t.list2}</p>
        </div>

        <div class="assessment-item">
          <span class="square"></span>
          <p>{t.list3}</p>
        </div>

        <div class="assessment-item">
          <span class="square"></span>
          <p>{t.list4}</p>
        </div>

      </div>

    </div>

    <div class="assessment-card">

      <p class="card-label">{t.cardLabel}</p>

      <p class="card-text">{t.cardText}</p>

      <a href={assessmentHref} class="assessment-button">
        {t.cardCta}
      </a>

      <p class="card-note">{t.cardNote}</p>

    </div>

  </div>

</section>

<style>
  .assessment {
    background: var(--color-ink);
    color: white;
  }

  .assessment-inner {
    width: min(100% - 4rem, 1400px);

    margin-inline: auto;

    padding-block: 2.5rem;

    display: grid;
    grid-template-columns: 1.2fr 0.8fr;

    gap: 4rem;
  }

  .assessment-label,
  .card-label {
    margin-bottom: 1.5rem;

    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.12em;

    color: var(--color-teal);
  }

  .assessment h2 {
    max-width: 10ch;

    margin-bottom: 2rem;

    color: white;
  }

  .assessment h2 span {
    color: var(--color-teal);
  }

  .assessment-text {
    max-width: 40rem;

    margin-bottom: 3rem;

    font-size: 1.1rem;
    line-height: 1.8;

    color: rgba(255,255,255,0.8);
  }

  .assessment-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .assessment-item {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .square {
    width: 12px;
    height: 12px;

    background: var(--color-teal);
  }

  .assessment-card {
    padding: 2rem;

    background: rgba(255,255,255,0.04);

    border-left: 2px solid var(--color-teal);

    height: fit-content;
  }

  .card-text {
    margin-bottom: 2rem;

    line-height: 1.8;

    color: rgba(255,255,255,0.82);
  }

  .assessment-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;

    width: 100%;

    padding: 1rem 1.5rem;

    background: var(--color-teal);
    color: var(--color-ink);

    text-decoration: none;

    font-weight: 700;
  }

  .card-note {
    margin-top: 1.5rem;

    font-size: 0.85rem;
    line-height: 1.6;

    color: rgba(255,255,255,0.45);
  }



  @media (max-width: 900px) {

    .assessment-inner {
      grid-template-columns: 1fr;

      gap: 3rem;

      padding-block: 2rem;
    }

    .assessment h2 {
      max-width: 12ch;
    }

    .assessment-text {
      font-size: 1rem;
    }

    .assessment-card {
      padding: 1.5rem;
    }

  }

</style>


  
