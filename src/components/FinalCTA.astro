---
import { strings, assessmentPath, type Lang } from "../i18n/strings";

interface Props {
  lang?: Lang;
}

const { lang = "tr" } = Astro.props;
const t = strings[lang].finalCta;
const assessmentHref = assessmentPath(lang);
const mailHref = `mailto:hello@newhr.ai?subject=${encodeURIComponent(t.mailSubject)}`;
---

<section class="final-cta" id="iletisim">

  <div class="final-cta-inner">

    <p class="eyebrow">{t.eyebrow}</p>

    <h2>{t.heading}</h2>

    <p class="final-cta-text">{t.body}</p>

    <div class="final-cta-actions">
      <a href={assessmentHref} class="cta-primary">{t.primaryCta}</a>
      <a
        href={mailHref}
        class="cta-secondary"
      >{t.secondaryCta}</a>
    </div>

    <p class="final-cta-trust">{t.trustLine}</p>

  </div>

</section>

<style>
  .final-cta {
    background: var(--color-ink);
    color: var(--color-paper);
  }

  .final-cta-inner {
    width: min(100% - 4rem, 1000px);

    margin-inline: auto;

    padding-block: 3rem;

    text-align: center;
  }

  .final-cta h2 {
    max-width: 14ch;

    margin-inline: auto;

    margin-top: 1rem;
    margin-bottom: 2rem;
  }

  .final-cta-text {
    max-width: 42rem;

    margin-inline: auto;
    margin-bottom: 3rem;

    font-size: 1.15rem;
    line-height: 1.8;

    color: rgba(255, 255, 255, 0.75);
  }

  .final-cta-actions {
    display: flex;
    justify-content: center;
    flex-wrap: wrap;
    gap: 1rem;
  }

  .cta-primary,
  .cta-secondary {
    display: inline-flex;
    align-items: center;
    justify-content: center;

    padding: 1.1rem 2rem;

    text-decoration: none;

    font-weight: 700;
  }

  .cta-primary {
    background: var(--color-teal);
    color: var(--color-ink);
  }

  .cta-primary:hover {
    opacity: 0.92;
  }

  .cta-secondary {
    background: transparent;
    color: var(--color-paper);

    border: 1px solid rgba(255, 255, 255, 0.45);

    transition: border-color 0.2s;
  }

  .cta-secondary:hover {
    border-color: rgba(255, 255, 255, 0.85);
  }

  @media (max-width: 600px) {
    .cta-primary,
    .cta-secondary {
      width: 100%;
    }
  }

  .final-cta-trust {
    margin-top: 1.5rem;

    font-size: 0.85rem;
    font-weight: 600;
    letter-spacing: 0.04em;

    color: rgba(255, 255, 255, 0.8);
  }
</style>