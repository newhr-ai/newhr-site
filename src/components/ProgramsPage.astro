---
import { strings, assessmentPath, type Lang } from "../i18n/strings";

interface Props {
  lang?: Lang;
}

const { lang = "tr" } = Astro.props;
const t = strings[lang].programs;
const hero = strings[lang].hero;
const fc = strings[lang].finalCta;
const assessmentHref = assessmentPath(lang);
const mailHref = `mailto:hello@newhr.ai?subject=${encodeURIComponent(fc.mailSubject)}`;
---

<section class="programs-page">

  <div class="pp-inner">

    <p class="eyebrow">{t.eyebrow}</p>

    <h1>{t.heading}</h1>

    <p class="pp-intro">{t.intro}</p>

    <div class="pp-list">
      {t.items.map((item) => (
        <article class="pp-card">
          <div class="pp-meta">
            <span class="pp-num">{item.number}</span>
            <span class="pp-sep">·</span>
            <span class="pp-tier">{item.tier}</span>
          </div>
          <div class="pp-main">
            <h2>{item.title}</h2>
            <p class="pp-body">{item.body}</p>
            {item.number === "01" && (
              <a href={assessmentHref} class="pp-link">{hero.ctaAssessment}</a>
            )}
          </div>
        </article>
      ))}
    </div>

    <div class="pp-footer">
      <a href={mailHref} class="pp-cta">{fc.cta}</a>
    </div>

  </div>

</section>

<style>
  .programs-page {
    background: var(--color-ink);
    color: var(--color-paper);

    min-height: 100vh;
  }

  .pp-inner {
    width: min(100% - 4rem, 1100px);

    margin-inline: auto;

    /* Top padding clears the absolutely-positioned header. */
    padding-block: 9rem 4rem;
  }

  .programs-page h1 {
    margin-top: 1rem;
    margin-bottom: 1.5rem;

    max-width: 18ch;

    font-size: clamp(2.4rem, 5vw, 3.6rem);
    font-weight: 800;
  }

  .pp-intro {
    margin-bottom: 4rem;

    max-width: 52ch;

    font-size: 1.15rem;
    font-weight: 700;
    letter-spacing: -0.01em;

    color: var(--color-paper);
  }

  .pp-list {
    display: grid;
    gap: 1.5rem;
  }

  .pp-card {
    padding: 2.25rem;

    background: #141414;

    border-top: 2px solid var(--color-teal);

    display: grid;
    grid-template-columns: 220px 1fr;
    gap: 2rem;
  }

  .pp-meta {
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;

    color: var(--color-teal);

    display: flex;
    gap: 0.45rem;
    align-items: baseline;
  }

  .pp-sep {
    opacity: 0.55;
  }

  .pp-main h2 {
    margin-bottom: 1rem;

    font-size: 1.6rem;
    line-height: 1.1;
    font-weight: 700;
  }

  .pp-body {
    max-width: 60ch;

    font-size: 1.02rem;
    line-height: 1.7;

    color: rgba(255, 255, 255, 0.72);
  }

  .pp-link {
    display: inline-flex;
    align-items: center;

    margin-top: 1.5rem;

    color: var(--color-paper);

    text-decoration: none;

    font-size: 0.9rem;
    font-weight: 700;

    border-bottom: 1px solid var(--color-teal);

    padding-bottom: 0.25rem;
  }

  .pp-link:hover {
    color: var(--color-teal);
  }

  .pp-footer {
    margin-top: 3.5rem;
  }

  .pp-cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;

    padding: 1.1rem 2rem;

    background: var(--color-teal);
    color: var(--color-ink);

    text-decoration: none;

    font-weight: 700;
  }

  .pp-cta:hover {
    opacity: 0.9;
  }

  @media (max-width: 760px) {
    .pp-inner {
      padding-block: 7rem 3rem;
    }

    .pp-card {
      grid-template-columns: 1fr;
      gap: 1rem;

      padding: 1.75rem;
    }

    .pp-cta {
      width: 100%;
    }
  }
</style>
