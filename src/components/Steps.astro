---
import { strings, assessmentPath, type Lang } from "../i18n/strings";

interface Props {
  lang?: Lang;
}

const { lang = "tr" } = Astro.props;
const t = strings[lang].steps;
const assessmentHref = assessmentPath(lang);
---

<section class="steps" id="yaklasim">

  <div class="steps-inner">

    <p class="eyebrow">{t.eyebrow}</p>

    <h2>{t.heading}</h2>

    <p class="steps-intro">{t.intro}</p>

    <div class="steps-grid">

      <article class="step-card">
        <p class="step-number">{t.step1Number}</p>
        <h3>{t.step1Title}</h3>
        <p>{t.step1Body}</p>
        <a href={assessmentHref} class="step-link">{t.step1Link}</a>
      </article>

      <article class="step-card">
        <p class="step-number">{t.step2Number}</p>
        <h3>{t.step2Title}</h3>
        <p>{t.step2Body}</p>
      </article>

      <article class="step-card">
        <p class="step-number">{t.step3Number}</p>
        <h3>{t.step3Title}</h3>
        <p>{t.step3Body}</p>
      </article>

    </div>

  </div>

</section>

<style>
  .steps {
    background: var(--color-paper);
    color: var(--color-ink);
  }

  .steps-inner {
    width: min(100% - 4rem, 1400px);

    margin-inline: auto;

    padding-block: 2.5rem;
  }

  .steps h2 {
    margin-top: 1rem;
    margin-bottom: 1rem;

    max-width: 16ch;
  }

  .steps-intro {
    margin-bottom: 4rem;

    font-size: 1.1rem;
    font-weight: 700;
    letter-spacing: -0.01em;

    color: var(--color-ink);
  }

  .step-link {
    display: inline-flex;
    align-items: center;

    margin-top: 1.5rem;

    color: var(--color-ink);

    text-decoration: none;

    font-size: 0.9rem;
    font-weight: 700;

    border-bottom: 1px solid var(--color-teal);

    padding-bottom: 0.25rem;
  }

  .step-link:hover {
    color: var(--color-teal);
  }

  .steps-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);

    gap: 1.5rem;
  }

  .step-card {
    padding: 2rem;

    background: white;

    border-top: 2px solid var(--color-ink);
  }

  .step-number {
    margin-bottom: 1.5rem;

    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.12em;

    color: var(--color-teal);
  }

  .step-card h3 {
    margin-bottom: 1.5rem;

    font-size: 2rem;
    line-height: 1.05;
  }

  .step-card p:last-child {
    font-size: 1rem;
    line-height: 1.7;
  }

  @media (max-width: 900px) {

  .steps-grid {
    grid-template-columns: 1fr;
  }

  .steps-inner {
    padding-block: 2rem;
  }

  .step-card h3 {
    font-size: 1.5rem;
  }

}
</style>