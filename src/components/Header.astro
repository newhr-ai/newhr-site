---
import { strings, assessmentPath, type Lang } from "../i18n/strings";

interface Props {
  lang?: Lang;
}

const { lang = "tr" } = Astro.props;
const t = strings[lang].nav;
const home = lang === "en" ? "/en/" : "/";
const assessmentHref = assessmentPath(lang);
---

<header class="nav">
  <div class="nav-inner">

    <a href={home} class="nav-logo">
      new<span>hr.ai</span>
    </a>

    <nav class="nav-links">
      <a href={`${home}#yaklasim`}>{t.yaklasim}</a>
      <a href={`${home}#hakkinda`}>{t.hakkinda}</a>
      <a href={`${home}#referanslar`}>{t.referanslar}</a>
      <a href={`${home}#iletisim`}>{t.iletisim}</a>
    </nav>

    <div class="nav-right">

      <a href={assessmentHref} class="nav-assessment">
        {t.assessmentCta}
      </a>

      <nav class="lang-toggle">
        <a href="/" data-lang="tr" aria-current={lang === "tr" ? "true" : "false"}>TR</a>
        <a href="/en/" data-lang="en" aria-current={lang === "en" ? "true" : "false"}>EN</a>
      </nav>

    </div>
  </div>
</header>

<style>
  .nav {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    padding-block: 0.75rem;
    background: transparent;
    border-bottom: none;
  }

  .nav-inner {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: 1rem;
  }

  .nav-inner > .nav-logo {
    justify-self: start;
  }

  .nav-inner > .nav-links {
    justify-self: center;
  }

  .nav-inner > .nav-right {
    justify-self: end;
  }

  .nav-logo {
    text-decoration: none;

    font-size: 1.4rem;
    font-weight: 800;
    letter-spacing: -0.04em;

    color: #fff;
  }

  .nav-logo span {
    color: var(--color-teal);
  }

  .nav-right {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .lang-toggle {
    display: flex;

    border: 1.5px solid rgba(255,255,255,0.6);
  }

  .lang-toggle a {
    padding: 0.45rem 0.75rem;

    text-decoration: none;

    color: #fff;

    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.08em;
  }

  .lang-toggle a[aria-current="true"] {
    background: rgba(255,255,255,0.9);
    color: #0A0A0A;
  }

  .nav-cta {
    padding: 0.9rem 1.2rem;

    background: var(--color-ink);
    color: white;

    text-decoration: none;

    font-size: 0.85rem;
    font-weight: 700;
    letter-spacing: 0.02em;
  }

  .nav-cta:hover {
    opacity: 0.9;
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 1.75rem;
    line-height: 1;
  }

  .nav-links a {
    display: inline-flex;
    align-items: center;
    line-height: 1;
    text-decoration: none;
    color: rgba(255,255,255,0.85);
    font-size: 0.9rem;
    font-weight: 600;
  }

  .nav-links a:hover {
    color: var(--color-teal);
  }

  .nav-assessment {
    display: inline-flex;
    align-items: center;

    padding: 0.7rem 1.1rem;

    background: var(--color-teal);
    color: var(--color-ink);

    text-decoration: none;

    font-size: 0.85rem;
    font-weight: 700;
    letter-spacing: 0.01em;

    animation: nav-assessment-glow 2.4s ease-in-out infinite;

    transition: transform 0.18s ease;
  }

  .nav-assessment:hover {
    transform: translateY(-1px);
  }

  @keyframes nav-assessment-glow {
    0%, 100% {
      box-shadow:
        0 0 0 0 rgba(93,227,211,0.55),
        0 0 12px 2px rgba(93,227,211,0.35);
    }
    50% {
      box-shadow:
        0 0 0 8px rgba(93,227,211,0.0),
        0 0 28px 8px rgba(93,227,211,0.65);
    }
  }

  @media (max-width: 900px) {
    .nav-links {
      display: none;
    }

    .nav-assessment {
      padding: 0.55rem 0.85rem;
      font-size: 0.78rem;
    }
  }
</style>

<script is:inline>
  document.querySelectorAll(".lang-toggle a[data-lang]").forEach(function (a) {
    a.addEventListener("click", function () {
      try {
        localStorage.setItem("nh_lang", a.getAttribute("data-lang"));
      } catch (e) {}
    });
  });
</script>