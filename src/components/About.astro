---
import { strings, type Lang } from "../i18n/strings";

interface Props {
  lang?: Lang;
}

const { lang = "tr" } = Astro.props;
const t = strings[lang].about;
---

<section class="about" id="hakkinda">

  <div class="about-inner">

    <div class="about-image">
      <img
        src="/images/Tolga_portrait_BW.jpg"
        alt="Tolga Temtek"
      />
    </div>

    <div class="about-content">

      <p class="eyebrow">{t.eyebrow}</p>

      <h2>{t.heading}</h2>

      <p class="about-text">{t.body}</p>

      <a
        href="https://www.linkedin.com/in/tolgatemtek/"
        class="about-link"
        target="_blank"
        rel="noopener noreferrer"
      >
        {t.link}
      </a>

    </div>

  </div>

</section>

<style>
  .about {
    background: var(--color-paper);
    color: var(--color-ink);
  }

  .about-inner {
    width: min(100% - 4rem, 1400px);

    margin-inline: auto;

    padding-block: 2.5rem;

    display: grid;
    grid-template-columns: 250px 1fr;

    gap: 5rem;

    align-items: center;
  }

  .about-image {
    position: relative;
    max-width: 250px;
    padding: 0 1rem 1rem 0;
  }

  .about-image::before {
    content: "";
    position: absolute;
    inset: 1rem 0 0 1rem;
    background: var(--color-teal);
    border-radius: 999px 999px 0 0;
    z-index: 0;
  }

  .about-image img {
    position: relative;
    z-index: 1;

    width: 100%;

    aspect-ratio: 4 / 5;

    object-fit: cover;
    object-position: center top;

    display: block;

    border-radius: 999px 999px 0 0;

    filter: grayscale(100%);
  }

  .about h2 {
    max-width: 10ch;

    margin-top: 1rem;
    margin-bottom: 2rem;
  }

  .about-text {
    max-width: 40rem;

    margin-bottom: 2rem;

    font-size: 1.1rem;
    line-height: 1.8;

    color: rgba(0,0,0,0.75);
  }

  .about-link {
    display: inline-flex;
    align-items: center;

    color: var(--color-ink);

    text-decoration: none;

    font-weight: 700;

    border-bottom: 1px solid var(--color-teal);

    padding-bottom: 0.3rem;
  }

  @media (max-width: 900px) {

    .about-inner {
      grid-template-columns: 1fr;

      gap: 3rem;

      padding-block: 2rem;
    }

    .about-image {
      max-width: 260px;
      margin-inline: auto;
    }

  }
</style>