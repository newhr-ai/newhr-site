---
import { strings, type Lang } from "../i18n/strings";

interface Props {
  lang?: Lang;
}

const { lang = "tr" } = Astro.props;
const t = strings[lang].about;
---

<section class="about" id="hakkinda">

  <div class="about-inner">

    <div class="about-content">

      <p class="eyebrow">{t.eyebrow}</p>

      <h2>{t.heading}</h2>

      <p class="about-text">{t.body}</p>

      <ul class="about-tags">
        {t.tags.map((tag) => (
          <li class="about-tag">{tag}</li>
        ))}
      </ul>

      <a href={t.linkHref} class="about-link">{t.link}</a>

    </div>

    <div class="about-photo">
      <img
        src="/images/tolga_about.jpg"
        alt={`Tolga Temtek — ${t.photoChip}`}
        width="380"
        height="475"
        loading="lazy"
      />
      <span class="photo-pill">{t.photoPill}</span>
      <span class="photo-chip">{t.photoChip}</span>
      <span class="photo-bar"></span>
    </div>

  </div>

</section>

<style>
  .about {
    background: var(--color-ink);
    color: var(--color-paper);
  }

  .about-inner {
    width: min(100% - 4rem, 1400px);

    margin-inline: auto;

    padding-block: 2.5rem;

    display: grid;
    grid-template-columns: 1fr 380px;

    gap: 5rem;

    align-items: center;
  }

  .about h2 {
    max-width: 18ch;

    margin-top: 1rem;
    margin-bottom: 1.5rem;
  }

  .about-text {
    max-width: 46rem;

    margin-bottom: 2rem;

    font-size: 1.1rem;
    line-height: 1.8;

    color: var(--color-paper);
  }

  .about-tags {
    list-style: none;
    padding: 0;

    margin-bottom: 2rem;

    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
  }

  .about-tag {
    border: 1px solid var(--color-paper);

    color: var(--color-paper);

    padding: 0.45rem 1rem;

    font-size: 0.85rem;
    font-weight: 600;

    border-radius: 999px;

    transition: background 0.2s, color 0.2s, border-color 0.2s;
  }

  .about-tag:hover {
    background: var(--color-teal);
    color: var(--color-ink);
    border-color: var(--color-teal);
  }

  .about-link {
    display: inline-flex;
    align-items: center;

    color: var(--color-paper);

    text-decoration: none;

    font-weight: 700;

    border-bottom: 2px solid var(--color-teal);

    padding-bottom: 0.3rem;
  }

  /* Photo frame — portrait 4/5, B&W, teal bar + chip + pill. */
  .about-photo {
    position: relative;

    max-width: 380px;
    width: 100%;

    margin-left: auto;
  }

  .about-photo img {
    display: block;

    width: 100%;
    aspect-ratio: 4 / 5;

    object-fit: cover;
    object-position: center top;

    filter: grayscale(1);

    background: var(--color-ink);
  }

  .photo-bar {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;

    height: 5px;

    background: var(--color-teal);
  }

  .photo-chip {
    position: absolute;
    left: 16px;
    bottom: 21px;

    background: #0A0A0A;
    color: #FFFFFF;

    padding: 0.5rem 0.85rem;

    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.03em;
  }

  .photo-pill {
    position: absolute;
    top: 16px;
    right: 16px;

    background: var(--color-teal);
    color: var(--color-ink);

    padding: 0.4rem 0.8rem;

    border-radius: 999px;

    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  @media (max-width: 900px) {
    .about-inner {
      grid-template-columns: 1fr;

      gap: 3rem;

      padding-block: 2rem;
    }

    .about-photo {
      margin-inline: auto;
    }
  }
</style>
