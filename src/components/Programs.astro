---
import { strings, type Lang } from "../i18n/strings";

interface Props {
  lang?: Lang;
}

const { lang = "tr" } = Astro.props;
const t = strings[lang].programs;
---

<section class="programs" id="programs">

  <div class="programs-inner">

    <p class="eyebrow">{t.eyebrow}</p>

    <h2>{t.heading}</h2>

    <p class="programs-intro">{t.intro}</p>

    <div class="programs-grid">
      {t.items.map((item) => (
        <article class="program-card">
          <p class="program-meta">
            <span class="program-number">{item.number}</span>
            <span class="program-sep">·</span>
            <span class="program-tier">{item.tier}</span>
          </p>
          <h3>{item.title}</h3>
          <p class="program-body">{item.body}</p>
        </article>
      ))}
    </div>

    <a href={t.ctaHref} class="programs-cta">{t.cta}</a>

  </div>

</section>

<style>
  .programs {
    background: var(--color-ink);
    color: var(--color-paper);
  }

  .programs-inner {
    width: min(100% - 4rem, 1400px);

    margin-inline: auto;

    padding-block: 2.5rem;
  }

  .programs h2 {
    margin-top: 1rem;
    margin-bottom: 1rem;

    max-width: 20ch;
  }

  .programs-intro {
    margin-bottom: 3rem;

    font-size: 1.1rem;
    font-weight: 700;
    letter-spacing: -0.01em;

    color: var(--color-paper);
  }

  .programs-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);

    gap: 1.5rem;
  }

  .program-card {
    padding: 2rem;

    background: #141414;

    border-top: 2px solid var(--color-teal);

    display: flex;
    flex-direction: column;
  }

  .program-meta {
    margin-bottom: 1.25rem;

    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;

    color: var(--color-teal);

    display: flex;
    gap: 0.45rem;
    align-items: baseline;
  }

  .program-sep {
    opacity: 0.55;
  }

  .program-card h3 {
    margin-bottom: 1rem;

    font-size: 1.4rem;
    line-height: 1.1;
  }

  .program-body {
    font-size: 0.98rem;
    line-height: 1.6;

    color: rgba(255, 255, 255, 0.72);
  }

  .programs-cta {
    display: inline-flex;
    align-items: center;

    margin-top: 2.5rem;

    color: var(--color-paper);

    text-decoration: none;

    font-size: 0.95rem;
    font-weight: 700;

    border-bottom: 1px solid var(--color-teal);

    padding-bottom: 0.25rem;
  }

  .programs-cta:hover {
    color: var(--color-teal);
  }

  @media (max-width: 1100px) {
    .programs-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 900px) {
    .programs-inner {
      padding-block: 2rem;
    }
  }

  @media (max-width: 560px) {
    .programs-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
