---
import { strings, assessmentPath, type Lang } from "../i18n/strings";

interface Props {
  lang?: Lang;
}

const { lang = "tr" } = Astro.props;
const t = strings[lang].footer;
const home = lang === "en" ? "/en/" : "/";
const assessmentHref = assessmentPath(lang);
const privacyHref = lang === "en" ? "/en/privacy/" : "/privacy/";
---

<footer class="footer">

  <div class="footer-inner">

    <div class="footer-top">

      <a href={home} class="footer-logo">
        new<span>hr.ai</span>
      </a>

      <p class="footer-tagline">{t.tagline}</p>

    </div>

    <div class="footer-grid">

      <div>
        <p class="footer-label">{t.pagesLabel}</p>

        <nav class="footer-links">
          <a href={home}>{t.home}</a>
          <a href={`${home}#workbench`}>{t.workbench}</a>
          <a href={assessmentHref}>{t.assessment}</a>
          <a href={`${home}#hakkinda`}>{t.about}</a>
          <a href="mailto:hello@newhr.ai">{t.contact}</a>
        </nav>
      </div>

      <div>
        <p class="footer-label">{t.contactLabel}</p>

        <nav class="footer-links">
          <a href="mailto:hello@newhr.ai">
            hello@newhr.ai
          </a>

          <a
            href="https://www.linkedin.com/in/tolgatemtek/"
            target="_blank"
            rel="noopener noreferrer"
          >
            LinkedIn
          </a>
        </nav>
      </div>

    </div>

    <div class="footer-bottom">

      <p>{t.copyright} · <a href={privacyHref}>{t.privacy}</a></p>

      <p>{t.mantra}</p>

    </div>

  </div>

</footer>

<style>
  .footer {
    background: var(--color-ink);
    color: white;
  }

  .footer-inner {
    width: min(100% - 4rem, 1400px);

    margin-inline: auto;

    padding-top: 2.5rem;
    padding-bottom: 1.25rem;
  }

  .footer-top {
    margin-bottom: 1.75rem;
  }

  .footer-logo {
    display: inline-block;

    margin-bottom: 0.4rem;

    color: white;

    text-decoration: none;

    font-size: 1.4rem;
    font-weight: 800;
    letter-spacing: -0.04em;
  }

  .footer-logo span {
    color: var(--color-teal);
  }

  .footer-tagline {
    font-size: 0.72rem;
    letter-spacing: 0.12em;

    color: rgba(255,255,255,0.55);
  }

  .footer-grid {
    display: grid;
    grid-template-columns: max-content max-content;

    gap: 1rem 5rem;

    margin-bottom: 1.75rem;
  }

  .footer-label {
    margin-bottom: 0.6rem;

    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.12em;

    color: var(--color-teal);
  }

  .footer-links {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .footer-links a {
    color: white;

    text-decoration: none;

    font-size: 0.88rem;
  }

  .footer-links a:hover {
    color: var(--color-teal);
  }

  .footer-bottom {
    display: flex;
    justify-content: space-between;

    padding-top: 1rem;

    border-top: 1px solid rgba(255,255,255,0.1);

    font-size: 0.78rem;

    color: rgba(255,255,255,0.5);
  }

  .footer-bottom a {
    color: inherit;
    text-decoration: underline;
  }

  .footer-bottom a:hover {
    color: var(--color-teal);
  }

  @media (max-width: 700px) {
    .footer-grid {
      grid-template-columns: 1fr;
      gap: 1.25rem;
    }

    .footer-bottom {
      flex-direction: column;
      gap: 0.4rem;
    }
  }
</style>