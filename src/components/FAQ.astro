---
import { strings, type Lang } from "../i18n/strings";

interface Props {
  lang?: Lang;
}

const { lang = "tr" } = Astro.props;
const t = strings[lang].faq;
---

<section class="faq">

  <div class="faq-inner">

    <p class="eyebrow">{t.eyebrow}</p>

    <h2>{t.heading}</h2>

    <div class="faq-list">
      {t.items.map((item) => (
        <details class="faq-item">
          <summary>
            <span class="faq-q">{item.q}</span>
            <span class="faq-mark" aria-hidden="true"></span>
          </summary>
          <p class="faq-a">{item.a}</p>
        </details>
      ))}
    </div>

  </div>

</section>

<style>
  .faq {
    background: var(--color-ink);
    color: var(--color-paper);
  }

  .faq-inner {
    width: min(100% - 4rem, 1000px);

    margin-inline: auto;

    padding-block: 2.5rem;
  }

  .faq h2 {
    margin-top: 1rem;
    margin-bottom: 3rem;
  }

  .faq-list {
    border-top: 0.5px solid rgba(255,255,255,0.18);
  }

  .faq-item {
    border-bottom: 0.5px solid rgba(255,255,255,0.18);
  }

  .faq-item summary {
    list-style: none;
    cursor: pointer;

    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;

    padding-block: 1.5rem;

    font-size: 1.2rem;
    font-weight: 700;
    line-height: 1.3;

    color: var(--color-paper);
  }

  .faq-item summary::-webkit-details-marker {
    display: none;
  }

  /* Plus / minus toggle, teal accent, no shadow. */
  .faq-mark {
    position: relative;
    flex: 0 0 auto;
    width: 16px;
    height: 16px;
  }

  .faq-mark::before,
  .faq-mark::after {
    content: "";
    position: absolute;
    background: var(--color-teal);
  }

  .faq-mark::before {
    top: 7px;
    left: 0;
    width: 16px;
    height: 2px;
  }

  .faq-mark::after {
    top: 0;
    left: 7px;
    width: 2px;
    height: 16px;
    transition: transform 0.2s ease;
  }

  .faq-item[open] .faq-mark::after {
    transform: scaleY(0);
  }

  .faq-a {
    padding-bottom: 1.5rem;

    max-width: 60ch;

    font-size: 1.05rem;
    line-height: 1.7;

    color: rgba(255, 255, 255, 0.72);
  }

  @media (max-width: 900px) {
    .faq-inner {
      padding-block: 2rem;
    }

    .faq-item summary {
      font-size: 1.05rem;
    }
  }
</style>
