---
import Header from "../components/Header.astro";

import "../styles/global.css";

interface Props {
  title?: string;
}

const {
  title = "New HR AI",
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{title}</title>
  </head>

<body>
  <main>
    <Header />
    <slot />
  </main>
</body>
</html>