---
import Header from "../components/Header.astro";
import type { Lang } from "../i18n/strings";

import "../styles/global.css";

interface Props {
  title?: string;
  lang?: Lang;
}

const {
  title = "New HR AI",
  lang = "tr",
} = Astro.props;

// Cookie-consent banner copy (localized per page).
const consent =
  lang === "en"
    ? {
        text: "We use cookies to understand how this site is used. You can accept or decline.",
        accept: "Accept",
        decline: "Decline",
        privacy: "Privacy policy",
        privacyHref: "/en/privacy/",
      }
    : {
        text: "Sitenin nasıl kullanıldığını anlamak için çerez kullanıyoruz. Kabul edebilir veya reddedebilirsiniz.",
        accept: "Kabul et",
        decline: "Reddet",
        privacy: "Gizlilik politikası",
        privacyHref: "/privacy/",
      };
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="apple-touch-icon" href="/favicon.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <!-- Warm DNS/TLS to the assessment subdomain so the "Take Assessment"
         cross-domain jump is near-instant on click. -->
    <link rel="preconnect" href="https://assessment.newhr.ai" />
    <link rel="dns-prefetch" href="https://assessment.newhr.ai" />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;700;800&display=swap"
    />
    <script is:inline>
      // First-visit language routing is handled server-side by a Netlify
      // Edge Function (netlify/edge-functions/lang-redirect.js) using the
      // visitor's country. This client-side script only enforces a
      // previously remembered manual choice (nh_lang in localStorage) so
      // that internal navigation between TR and EN stays consistent.
      (function () {
        try {
          var path = location.pathname;
          var isEn = path === "/en" || path.indexOf("/en/") === 0;
          var stored = localStorage.getItem("nh_lang");
          if (stored === "en" && !isEn) {
            location.replace("/en/" + location.search + location.hash);
          } else if (stored === "tr" && isEn) {
            location.replace("/" + location.search + location.hash);
          }
        } catch (e) {}
      })();
    </script>
  </head>

  <body>
    <main class="site-main">
      <Header lang={lang} />
      <slot />
    </main>

    <!-- Cookie consent banner. Analytics load ONLY after "Accept" (GDPR). -->
    <div id="nh-consent" class="nh-consent" role="dialog" aria-label="cookie consent">
      <p class="nh-consent-text">
        {consent.text}
        <a href={consent.privacyHref}>{consent.privacy} →</a>
      </p>
      <div class="nh-consent-actions">
        <button type="button" id="nh-consent-decline" class="nh-consent-btn decline">
          {consent.decline}
        </button>
        <button type="button" id="nh-consent-accept" class="nh-consent-btn accept">
          {consent.accept}
        </button>
      </div>
    </div>

    <script is:inline>
      // GDPR: analytics (Microsoft Clarity + GA4) are injected ONLY after the
      // visitor accepts. Nothing analytics-related — and no non-essential
      // cookie — loads before that. Choice persists in localStorage.nh_consent.
      (function () {
        var KEY = "nh_consent";
        var injected = false;

        function injectAnalytics() {
          if (injected) return;
          injected = true;

          // Microsoft Clarity
          (function (c, l, a, r, i, t, y) {
            c[a] = c[a] || function () { (c[a].q = c[a].q || []).push(arguments); };
            t = l.createElement(r); t.async = 1;
            t.src = "https://www.clarity.ms/tag/" + i;
            y = l.getElementsByTagName(r)[0]; y.parentNode.insertBefore(t, y);
          })(window, document, "clarity", "script", "wm99has0c8");

          // Google Analytics 4
          var ga = document.createElement("script");
          ga.async = true;
          ga.src = "https://www.googletagmanager.com/gtag/js?id=G-YQY8YN6XHT";
          document.head.appendChild(ga);
          window.dataLayer = window.dataLayer || [];
          function gtag() { window.dataLayer.push(arguments); }
          window.gtag = gtag;
          gtag("js", new Date());
          gtag("config", "G-YQY8YN6XHT");
        }

        function hideBanner() {
          var b = document.getElementById("nh-consent");
          if (b) b.classList.remove("show");
        }

        try {
          var choice = localStorage.getItem(KEY);
          if (choice === "accept") {
            injectAnalytics();
          } else if (!choice) {
            var b = document.getElementById("nh-consent");
            if (b) b.classList.add("show");
          }
          // "decline" → inject nothing, show nothing.
        } catch (e) {}

        var acceptBtn = document.getElementById("nh-consent-accept");
        var declineBtn = document.getElementById("nh-consent-decline");
        if (acceptBtn)
          acceptBtn.addEventListener("click", function () {
            try { localStorage.setItem(KEY, "accept"); } catch (e) {}
            injectAnalytics();
            hideBanner();
          });
        if (declineBtn)
          declineBtn.addEventListener("click", function () {
            try { localStorage.setItem(KEY, "decline"); } catch (e) {}
            hideBanner();
          });
      })();
    </script>
  </body>
</html>

<style is:global>
  .site-main {
    width: 100%;
  }

  /* Cookie consent banner — hidden until JS shows it (first visit only). */
  .nh-consent {
    display: none;
    position: fixed;
    left: 0;
    right: 0;
    bottom: 0;
    z-index: 1000;

    align-items: center;
    justify-content: center;
    gap: 1.25rem;
    flex-wrap: wrap;

    padding: 1rem 1.25rem;

    background: #0A0A0A;
    color: #fff;

    border-top: 1px solid rgba(255, 255, 255, 0.15);

    font-family: var(--font-primary);
    font-size: 0.9rem;
  }

  .nh-consent.show {
    display: flex;
  }

  .nh-consent-text {
    margin: 0;
    max-width: 70ch;
    line-height: 1.5;
    color: rgba(255, 255, 255, 0.92);
  }

  .nh-consent-text a {
    color: #5DE3D3;
    text-decoration: underline;
    white-space: nowrap;
  }

  .nh-consent-actions {
    display: flex;
    gap: 0.6rem;
    flex: 0 0 auto;
  }

  .nh-consent-btn {
    font-family: inherit;
    font-size: 0.85rem;
    font-weight: 700;

    padding: 0.6rem 1.2rem;

    border: 0;
    cursor: pointer;
  }

  .nh-consent-btn.accept {
    background: #5DE3D3;
    color: #0A0A0A;
  }

  .nh-consent-btn.accept:hover {
    opacity: 0.9;
  }

  .nh-consent-btn.decline {
    background: transparent;
    color: #fff;
    border: 1px solid rgba(255, 255, 255, 0.4);
  }

  .nh-consent-btn.decline:hover {
    border-color: rgba(255, 255, 255, 0.8);
  }

  @media (max-width: 640px) {
    .nh-consent {
      flex-direction: column;
      align-items: stretch;
      gap: 0.85rem;
      text-align: center;
    }

    .nh-consent-actions {
      justify-content: center;
    }

    .nh-consent-btn {
      flex: 1;
    }
  }
</style>