---
import Header from "../components/Header.astro";
import type { Lang } from "../i18n/strings";

import "../styles/global.css";

interface Props {
  title?: string;
  lang?: Lang;
}

const {
  title = "New HR AI",
  lang = "tr",
} = Astro.props;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="apple-touch-icon" href="/favicon.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <!-- Warm DNS/TLS to the assessment subdomain so the "Take Assessment"
         cross-domain jump is near-instant on click. -->
    <link rel="preconnect" href="https://assessment.newhr.ai" />
    <link rel="dns-prefetch" href="https://assessment.newhr.ai" />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;700;800&display=swap"
    />
    <script is:inline>
      // First-visit language routing is handled server-side by a Netlify
      // Edge Function (netlify/edge-functions/lang-redirect.js) using the
      // visitor's country. This client-side script only enforces a
      // previously remembered manual choice (nh_lang in localStorage) so
      // that internal navigation between TR and EN stays consistent.
      (function () {
        try {
          var path = location.pathname;
          var isEn = path === "/en" || path.indexOf("/en/") === 0;
          var stored = localStorage.getItem("nh_lang");
          if (stored === "en" && !isEn) {
            location.replace("/en/" + location.search + location.hash);
          } else if (stored === "tr" && isEn) {
            location.replace("/" + location.search + location.hash);
          }
        } catch (e) {}
      })();
    </script>
  </head>

  <body>
    <main class="site-main">
      <Header lang={lang} />
      <slot />
    </main>
  </body>
</html>

<style is:global>
  .site-main {
    width: 100%;
  }
</style>